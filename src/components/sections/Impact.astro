---
---

<section id="impact" class="py-16 bg-white border-b border-[var(--color-bd)]">
  <div class="max-w-5xl mx-auto px-6 grid grid-cols-2 md:grid-cols-4 gap-5 text-center">

    {[
      { count: 10, suffix: '年', label: 'Experience', desc: '体育教師として現場で課題を解決し続けた年数', color: 'text-[var(--color-or)]', delay: '0.05s', t: 'imp1' },
      { count: 3,  suffix: '件', label: 'Projects',   desc: '本番環境までデプロイした個人プロジェクト',   color: 'text-[var(--color-am2)]', delay: '0.15s', t: 'imp2' },
      { count: 80, suffix: '%', label: 'Time Saved',  desc: '指導案作成時間削減率（TAIIKU BASE）',       color: 'text-[var(--color-or)]', delay: '0.25s', t: 'imp3' },
      { count: 2,  suffix: 'h+', label: 'Weekly Saved', desc: 'エラー翻訳くんで週に節約できる学習時間',   color: 'text-[var(--color-am2)]', delay: '0.35s', t: 'imp4' },
    ].map(({ count, suffix, label, desc, color, delay, t }) => (
      <div class="impact-card p-8 rounded-xl bg-[var(--color-cream)] border border-[var(--color-bd)]" style={`transition-delay:${delay}`}>
        <span class={`block font-en font-extrabold leading-none mb-1 ${color}`}
          style="font-size:clamp(2rem,5vw,3.5rem);letter-spacing:-0.05em"
          data-count={count} data-suffix={suffix} data-t={`${t}_num`}>
          0{suffix}
        </span>
        <p class="font-en text-[0.62rem] font-bold text-[var(--color-sub)] tracking-[0.14em] uppercase mb-1">{label}</p>
        <p class="font-ja text-[0.78rem] text-[var(--color-sub)] leading-[1.65]" data-t={`${t}_desc`}>{desc}</p>
      </div>
    ))}

  </div>
</section>

<script>
import gsap from 'gsap';
import { ScrollTrigger } from 'gsap/ScrollTrigger';
gsap.registerPlugin(ScrollTrigger);

document.querySelectorAll<HTMLElement>('.impact-card').forEach((el) => {
  ScrollTrigger.create({ trigger: el, start: 'top 88%', onEnter: () => el.classList.add('reveal-in') });
});

document.querySelectorAll<HTMLElement>('[data-count]').forEach((el) => {
  ScrollTrigger.create({ trigger: el, start: 'top 85%',
    onEnter: () => {
      const tgt = +(el.dataset.count || 0), sfx = el.dataset.suffix || '';
      const dur = 1800, t0 = performance.now();
      (function tick(now: number) {
        const p = Math.min((now - t0) / dur, 1);
        const e2 = 1 - Math.pow(1 - p, 3);
        el.textContent = Math.round(e2 * tgt) + sfx;
        if (p < 1) requestAnimationFrame(tick);
      })(performance.now());
    }
  });
});
</script>
