---
// 記事が増えたらここに追加するだけ。OGP取得後はogImage/descriptionも埋める。
const posts: {
  url: string;
  title: string;
  titleEn: string;
  desc: string;
  descEn: string;
  emoji: string;
  tags: string[];
  date: string;
}[] = [
  // 例（記事ができたらコメントアウトを外してURLを入れる）:
  // {
  //   url: 'https://zenn.dev/yusu31/articles/xxxxxxx',
  //   title: '記事タイトル',
  //   titleEn: 'Article Title',
  //   desc: '記事の説明文',
  //   descEn: 'Article description',
  //   emoji: '📝',
  //   tags: ['React', 'TypeScript'],
  //   date: '2025-01-01',
  // },
];

const comingSoon = posts.length === 0;
---

<section id="blog" class="border-t border-[var(--color-bd)]">
  <div class="max-w-5xl mx-auto px-6 py-24">
    <div class="reveal mb-12">
      <p class="font-en text-[0.66rem] font-bold text-[var(--color-or)] tracking-[0.22em] uppercase mb-2">Blog</p>
      <h2
        class="font-ja font-bold text-[var(--color-tx)] mb-3"
        style="font-size:clamp(1.75rem,4.5vw,2.75rem);letter-spacing:-0.03em;line-height:1.1"
        data-t="blog_h"
      >
        書いたこと。
      </h2>
      <p class="font-ja text-[var(--color-sub)] text-[0.88rem] leading-[1.95] max-w-lg" data-t="blog_desc">
        学んだことを言語化して残す。アウトプットは最良のインプット。
      </p>
    </div>

    {comingSoon ? (
      <!-- Coming Soon -->
      <div class="reveal flex flex-col items-center justify-center py-20 border border-dashed border-[var(--color-bd)] rounded-2xl bg-[var(--color-cream)]">
        <div class="text-4xl mb-4">✍️</div>
        <p class="font-en font-bold text-[1.1rem] text-[var(--color-or)] tracking-tight mb-2" data-t="blog_soon_title">
          Coming Soon
        </p>
        <p class="font-ja text-[var(--color-sub)] text-[0.84rem] text-center leading-[1.9] max-w-xs" data-t="blog_soon_desc">
          Zenn で技術記事を準備中です。<br>公開したらここに掲載します。
        </p>
      </div>
    ) : (
      <!-- 記事カードグリッド -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
        {posts.map(({ url, title, titleEn, desc, descEn, emoji, tags, date }, i) => (
          <a
            href={url}
            target="_blank"
            rel="noopener noreferrer"
            class="blog-card reveal group relative bg-white border border-[var(--color-bd)] rounded-2xl overflow-hidden transition-all duration-300 hover:border-[#fdba74] hover:shadow-xl no-underline"
            style={`transition-delay:${(i + 1) * 0.1}s`}
          >
            <!-- サムネイル -->
            <div class="w-full aspect-video border-b border-[var(--color-bd)] flex items-center justify-center bg-gradient-to-br from-[#fff7ed] to-[#ffedd5]">
              <span class="text-5xl">{emoji}</span>
            </div>

            <!-- コンテンツ -->
            <div class="p-5">
              <div class="flex gap-1.5 flex-wrap mb-3">
                {tags.map((tag) => (
                  <span class="font-en text-[0.59rem] font-semibold px-2 py-0.5 bg-[var(--color-cream)] border border-[var(--color-bd)] rounded text-[var(--color-sub)]">{tag}</span>
                ))}
              </div>
              <p class="font-ja font-bold text-[var(--color-tx)] text-[1rem] mb-2 leading-snug group-hover:text-[var(--color-or)] transition-colors" data-blog-title data-ja={title} data-en={titleEn}>
                {title}
              </p>
              <p class="font-ja text-[0.79rem] text-[var(--color-sub)] leading-[1.65] mb-3" data-blog-desc data-ja={desc} data-en={descEn}>
                {desc}
              </p>
              <div class="flex items-center justify-between">
                <span class="font-en text-[0.7rem] text-[var(--color-sub)]">{date}</span>
                <span class="font-en text-[0.77rem] font-bold text-[var(--color-or)] transition-opacity group-hover:opacity-60">↗ Zenn</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    )}
  </div>
</section>

<script>
import gsap from 'gsap';
import { ScrollTrigger } from 'gsap/ScrollTrigger';
gsap.registerPlugin(ScrollTrigger);

document.querySelectorAll<HTMLElement>('.reveal').forEach((el) => {
  ScrollTrigger.create({ trigger: el, start: 'top 83%', onEnter: () => el.classList.add('reveal-in') });
});

/* i18n: 記事カードのタイトル・説明を切り替え */
function applyBlogLang(lang: string) {
  document.querySelectorAll<HTMLElement>('[data-blog-title]').forEach((el) => {
    el.textContent = lang === 'en' ? (el.dataset.en ?? '') : (el.dataset.ja ?? '');
  });
  document.querySelectorAll<HTMLElement>('[data-blog-desc]').forEach((el) => {
    el.textContent = lang === 'en' ? (el.dataset.en ?? '') : (el.dataset.ja ?? '');
  });
}

document.getElementById('lang-btn')?.addEventListener('click', () => {
  const lang = document.documentElement.lang;
  applyBlogLang(lang);
});
</script>
