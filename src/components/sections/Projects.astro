---
const projects = [
  {
    id: 'taiiku',
    label: 'TAIIKU',
    sub: 'Education × AI',
    tags: ['React', 'Spring Boot', 'Gemini API'],
    title: 'TAIIKU BASE',
    psi: {
      prob: '体育教師は指導案作成に毎週平均 3 時間以上を消費。テンプレートもなくハンドメイドが当たり前だった。',
      sol:  'Gemini API を組み込んだ React + Spring Boot 製プラットフォーム。クリック 3 回で指導案を自動生成。',
      imp:  '→ 10名テストで作成時間 80% 削減（3h → 36min）',
    },
    demoUrl: '#', githubUrl: '#',
    grad: 'from-[#fff7ed] to-[#ffedd5]', iconColor: 'text-[#f97316]',
    delay: '0.1s',
  },
  {
    id: 'task',
    label: 'TASK',
    sub: 'Full-Stack',
    tags: ['Spring Boot', 'React', 'PostgreSQL'],
    title: 'タスク管理アプリ',
    psi: {
      prob: 'タスク情報が Slack・メモ・メールに散乱し、共有・追跡に時間がかかる。',
      sol:  '認証・CRUD・権限管理・CI/CD を 1 人で構築。REST API 設計から本番デプロイまで一貫実装。',
      imp:  '→ 本番環境デプロイ済み。フルスタック開発能力の実証。',
    },
    demoUrl: '#', githubUrl: '#',
    grad: 'from-[#fffbeb] to-[#fef3c7]', iconColor: 'text-[#d97706]',
    delay: '0.2s',
  },
  {
    id: 'err',
    label: 'ERR→JP',
    sub: 'Chrome Extension',
    tags: ['Chrome 拡張', 'Gemini API', 'JavaScript'],
    title: 'エラー翻訳くん',
    psi: {
      prob: '英語のエラーメッセージで詰まる初学者が大量の時間を損失。',
      sol:  'エラーテキストを選択するだけで AI が日本語で即座に解説。Chrome Store 公開。',
      imp:  '→ 学習時間 週 2h+ 節約。自分自身が毎日利用中。',
    },
    demoUrl: '#', githubUrl: '#',
    grad: 'from-[#fef9f0] to-[#fde68a]', iconColor: 'text-[#b45309]',
    delay: '0.3s',
  },
];
---

<section id="projects" class="border-t border-[var(--color-bd)]">
  <div class="max-w-5xl mx-auto px-6 py-24">
    <div class="reveal mb-12">
      <p class="font-en text-[0.66rem] font-bold text-[var(--color-or)] tracking-[0.22em] uppercase mb-2">Projects</p>
      <h2 class="font-ja font-bold text-[var(--color-tx)] mb-3" style="font-size:clamp(1.75rem,4.5vw,2.75rem);letter-spacing:-0.03em;line-height:1.1" data-t="proj_h">
        作ったもの。
      </h2>
      <p class="font-ja text-[var(--color-sub)] text-[0.88rem] leading-[1.95] max-w-lg" data-t="proj_desc">
        「何を使ったか」ではなく、「誰の何を解決したか」で見せる。
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
      {projects.map(({ id, label, sub, tags, title, psi, demoUrl, githubUrl, grad, iconColor, delay }) => (
        <div class="proj-card reveal relative bg-white border border-[var(--color-bd)] rounded-2xl overflow-hidden transition-all duration-300 hover:border-[#fdba74] hover:shadow-xl"
          style={`transition-delay:${delay}`}>

          <!-- グレアエフェクト -->
          <div class="proj-glare absolute inset-0 rounded-2xl pointer-events-none opacity-0 transition-opacity duration-200 z-20"></div>

          <!-- サムネイル -->
          <div class={`w-full aspect-video border-b border-[var(--color-bd)] flex flex-col items-center justify-center bg-gradient-to-br ${grad}`}>
            <div class={`font-en font-extrabold text-[2rem] tracking-tight mb-1 ${iconColor}`}>{label}</div>
            <div class="font-en text-[0.6rem] font-bold tracking-[0.14em] uppercase text-[#a8a29e]">{sub}</div>
          </div>

          <!-- コンテンツ -->
          <div class="p-5 relative z-10">
            <div class="flex gap-1.5 flex-wrap mb-3">
              {tags.map((tag) => (
                <span class="font-en text-[0.59rem] font-semibold px-2 py-0.5 bg-[var(--color-cream)] border border-[var(--color-bd)] rounded text-[var(--color-sub)]">{tag}</span>
              ))}
            </div>

            <p class="font-ja font-bold text-[var(--color-tx)] text-[1rem] mb-3 leading-snug" data-t={`${id}_title`}>{title}</p>

            <!-- PSI -->
            <div class="mb-1.5 px-2.5 py-2 rounded-lg" style="background:#fff7f5;border-left:2.5px solid #fdba74">
              <p class="font-en text-[0.59rem] font-bold tracking-[0.12em] uppercase text-[#f97316] mb-0.5">Problem</p>
              <p class="font-ja text-[0.79rem] text-[var(--color-tx)] leading-[1.65]" data-t={`${id}_prob`}>{psi.prob}</p>
            </div>
            <div class="mb-1.5 px-2.5 py-2 rounded-lg" style="background:#fffbeb;border-left:2.5px solid #fcd34d">
              <p class="font-en text-[0.59rem] font-bold tracking-[0.12em] uppercase text-[#d97706] mb-0.5">Solution</p>
              <p class="font-ja text-[0.79rem] text-[var(--color-tx)] leading-[1.65]" data-t={`${id}_sol`}>{psi.sol}</p>
            </div>
            <div class="mb-3 px-2.5 py-2 rounded-lg" style="background:#fff7ed;border-left:2.5px solid #f97316">
              <p class="font-en text-[0.59rem] font-bold tracking-[0.12em] uppercase text-[#c2410c] mb-0.5">Impact</p>
              <p class="font-ja text-[0.79rem] font-bold text-[var(--color-or2)] leading-[1.65]" data-t={`${id}_imp`}>{psi.imp}</p>
            </div>

            <div class="flex gap-3">
              <a href={demoUrl} class="font-ja text-[0.77rem] font-bold text-[var(--color-or)] no-underline transition-opacity hover:opacity-60" data-t="demo_link">↗ デモを見る</a>
              <a href={githubUrl} class="font-ja text-[0.77rem] font-bold text-[var(--color-sub)] no-underline transition-opacity hover:opacity-60">GitHub</a>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
import gsap from 'gsap';
import { ScrollTrigger } from 'gsap/ScrollTrigger';
gsap.registerPlugin(ScrollTrigger);

document.querySelectorAll<HTMLElement>('.reveal').forEach((el) => {
  ScrollTrigger.create({ trigger: el, start: 'top 83%', onEnter: () => el.classList.add('reveal-in') });
});

/* 3D カードチルト */
document.querySelectorAll<HTMLElement>('.proj-card').forEach((card) => {
  const glare = card.querySelector<HTMLElement>('.proj-glare');
  card.addEventListener('mousemove', (e) => {
    const { left, top, width, height } = card.getBoundingClientRect();
    const x = (e.clientX - left - width / 2) / width;
    const y = (e.clientY - top  - height / 2) / height;
    card.style.transition = 'transform 0.08s ease, border-color 0.3s, box-shadow 0.3s';
    card.style.transform  = `perspective(900px) rotateY(${x * 12}deg) rotateX(${-y * 12}deg) scale(1.02)`;
    if (glare) {
      glare.style.opacity    = '1';
      glare.style.background = `radial-gradient(circle at ${e.clientX - left}px ${e.clientY - top}px, rgba(249,115,22,.07), transparent 65%)`;
    }
  });
  card.addEventListener('mouseleave', () => {
    card.style.transition = 'transform 0.65s cubic-bezier(.23,1,.32,1), border-color 0.3s, box-shadow 0.3s';
    card.style.transform  = 'perspective(900px) rotateY(0) rotateX(0) scale(1)';
    if (glare) glare.style.opacity = '0';
  });
});
</script>
