<footer class="border-t border-[var(--color-bd)]">
  <div class="max-w-5xl mx-auto px-6 py-8 flex items-center justify-between flex-wrap gap-4">
    <span class="font-en font-extrabold text-[0.9rem] tracking-tight text-[var(--color-tx)]">
      yu<em class="not-italic text-[var(--color-or)]">.</em>
    </span>
    <div class="flex gap-6">
      <a href="https://github.com/yusu31" class="font-en text-[0.72rem] text-[var(--color-sub)] no-underline transition-colors hover:text-[var(--color-or)]">GitHub</a>
      <a href="#" class="font-en text-[0.72rem] text-[var(--color-sub)] no-underline transition-colors hover:text-[var(--color-or)]">Zenn</a>
      <a href="#" class="font-en text-[0.72rem] text-[var(--color-sub)] no-underline transition-colors hover:text-[var(--color-or)]">X</a>
