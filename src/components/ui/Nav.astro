---
---

<nav id="nav" style="position:fixed;top:0;left:0;right:0;z-index:200;display:flex;align-items:center;justify-content:space-between;padding:1.2rem 3rem;transition:background .4s,border-color .4s;background:rgba(234,88,12,.85);backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);border-bottom:1px solid rgba(255,255,255,.12)">
  <a href="#" id="logo" style="font-family:var(--font-en);font-weight:800;font-size:1.1rem;letter-spacing:-.06em;color:#fff;text-decoration:none">
    yu<em style="font-style:normal;color:var(--color-am)">.</em>
  </a>

  <ul id="nav-list" style="list-style:none;display:flex;align-items:center;gap:2rem">
    <li><a href="#impact"   data-t="nav_impact"  class="nav-link" style="font-family:var(--font-ja);font-size:.82rem;font-weight:700;color:rgba(255,255,255,.7);text-decoration:none;transition:color .2s">数字で見る</a></li>
    <li><a href="#story"    data-t="nav_story"   class="nav-link" style="font-family:var(--font-ja);font-size:.82rem;font-weight:700;color:rgba(255,255,255,.7);text-decoration:none;transition:color .2s">ストーリー</a></li>
    <li><a href="#projects" data-t="nav_works"   class="nav-link" style="font-family:var(--font-ja);font-size:.82rem;font-weight:700;color:rgba(255,255,255,.7);text-decoration:none;transition:color .2s">作品</a></li>
    <li><a href="#contact"  data-t="nav_contact" class="nav-link" style="font-family:var(--font-ja);font-size:.82rem;font-weight:700;color:rgba(255,255,255,.7);text-decoration:none;transition:color .2s">連絡</a></li>
    <li>
      <button id="lang-btn" style="font-family:var(--font-en);font-size:.65rem;font-weight:700;letter-spacing:.1em;padding:.32rem .8rem;border-radius:999px;background:rgba(255,255,255,.15);color:#fff;border:none;cursor:pointer;transition:background .2s">
        EN
      </button>
    </li>
  </ul>
</nav>

<script>
  const nav    = document.getElementById('nav')!;
  const logo   = document.getElementById('logo')!;
  const hero   = document.getElementById('hero')!;
  const links  = document.querySelectorAll<HTMLElement>('.nav-link');
  const langBtn = document.getElementById('lang-btn')!;
  let isDark = true;

  window.addEventListener('scroll', () => {
    const inHero = hero.getBoundingClientRect().bottom > 0;
    if (inHero && !isDark) {
      isDark = true;
      nav.style.background = 'rgba(234,88,12,.85)';
      nav.style.borderBottomColor = 'rgba(255,255,255,.12)';
      logo.style.color = '#fff';
      links.forEach(a => { a.style.color = 'rgba(255,255,255,.7)'; });
      langBtn.style.background = 'rgba(255,255,255,.15)';
      langBtn.style.color = '#fff';
    } else if (!inHero && isDark) {
      isDark = false;
      nav.style.background = 'rgba(255,251,245,.95)';
      nav.style.borderBottomColor = 'var(--color-bd)';
      logo.style.color = 'var(--color-tx)';
      links.forEach(a => { a.style.color = 'var(--color-sub)'; });
      langBtn.style.background = 'var(--color-or2)';
      langBtn.style.color = '#fff';
    }
  }, { passive: true });

  /* ホバー */
  links.forEach(a => {
    a.addEventListener('mouseenter', () => { a.style.color = isDark ? 'var(--color-am)' : 'var(--color-or)'; });
    a.addEventListener('mouseleave', () => { a.style.color = isDark ? 'rgba(255,255,255,.7)' : 'var(--color-sub)'; });
  });
</script>
