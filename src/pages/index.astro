---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/ui/Nav.astro';
import Hero from '../components/sections/Hero.astro';
import Impact from '../components/sections/Impact.astro';
import Story from '../components/sections/Story.astro';
import Projects from '../components/sections/Projects.astro';
import Skills from '../components/sections/Skills.astro';
import Contact from '../components/sections/Contact.astro';
import Footer from '../components/ui/Footer.astro';
---

<Layout>
  <Nav />
  <main>
    <Hero />
    <Impact />
    <Story />
    <Projects />
    <Skills />
    <Contact />
  </main>
  <Footer />
</Layout>

<!-- サウンドボタン -->
<button id="snd-btn" aria-label="サウンド切替"
  class="fixed bottom-20 right-7 z-50 w-10 h-10 rounded-full flex items-center justify-center border-none transition-colors"
  style="background:rgba(194,65,12,.8);backdrop-filter:blur(12px)">
  <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" class="w-[18px] h-[18px]">
    <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/>
    <path d="M19.07 4.93a10 10 0 0 1 0 14.14" id="snd-big" opacity=".3"/>
    <path d="M15.54 8.46a5 5 0 0 1 0 7.07" id="snd-sm" opacity=".3"/>
  </svg>
</button>

<script>
/* ===== i18n ===== */
